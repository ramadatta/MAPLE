# MAPLE environment configuration
# Copy to .env and fill in your values

# --- LLM Configuration ---
# Blablador (recommended for Helmholtz/Jülich users):
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.blablador.fz-juelich.de/v1
# OPENAI_MODEL=your-model-name  # check Blablador docs

# OpenAI (alternative):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# GitLab Duo (alternative):
# GITLAB_TOKEN=glpat-...
# LLM_PROVIDER=gitlab

# LLM provider: auto | openai | gitlab
LLM_PROVIDER=auto

# Lock app to .env token only (no chat paste)
USE_ENV_TOKEN_ONLY=false
VERIFY_GITLAB_TOKEN=true

# --- Active OpenAI / Blablador settings ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=

# --- GitLab Duo settings ---
GITLAB_TOKEN=
GITLAB_HOST=https://gitlab.com
GITLAB_MODEL=gpt-5-mini-2025-08-07
GITLAB_AI_GATEWAY_URL=https://cloud.gitlab.com/ai/v1/proxy/openai/v1

# --- NCBI PubMed (optional, increases rate limits) ---
NCBI_EMAIL=
NCBI_API_KEY=
NCBI_TOOL=maple

# --- MAPLE Runtime Config ---
MAPLE_PAPERS_PER_GENE=5
MAPLE_MAX_EVIDENCE_PAPERS=60
MAPLE_ENABLE_FULLTEXT=true
MAPLE_ENABLE_LLM_EXTRACTION=true
MAPLE_LLM_EXTRACTION_MAX_PAPERS=20
MAPLE_TABLE_PAGE_SIZE=20

# --- Performance ---
# Concurrency for per-paper LLM extraction and full-text fetches (higher = faster,
# but watch provider rate limits). LLM cache makes repeat queries near-instant.
MAPLE_EVIDENCE_EXTRACTION_CONCURRENCY=8
MAPLE_FULLTEXT_FETCH_CONCURRENCY=8
MAPLE_ENABLE_LLM_CACHE=true
# Logging: DEBUG | INFO | WARNING | ERROR (default INFO)
MAPLE_LOG_LEVEL=INFO

# Evidence extraction: false = fast heuristic (default), true = slow LLM batch
EVIDENCE_USE_LLM=false
EVIDENCE_MAX_PAPERS_PER_GENE=3
